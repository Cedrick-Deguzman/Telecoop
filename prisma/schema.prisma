generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ClientStatus {
  active
  inactive
}

enum InvoiceStatus {
  paid
  pending
  overdue
}

enum PaymentMethod {
  cash
  gcash
  bank
}

model Plan {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  speed     String
  price     Float
  color     String
  features  Json
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[] @relation("PlanClients")
  isActive Boolean @default(true)

  @@map("plan")
}

model Client {
  id                 Int       @id @default(autoincrement())
  name               String
  accountNumber      String?    @unique
  phone              String?
  email              String?
  installationDate   DateTime
  dueDate            DateTime
  planId             Int?
  plan               Plan?     @relation("PlanClients", fields: [planId], references: [id])
  status             String
  monthlyFee         Float
  billingDay         Int       @default(15)
  address            String?
  latitude           Float?
  longitude          Float?
  reactivatedAt      DateTime?
  lastNapboxId       Int?
  lastPortNumber     Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  payment            Payment[]
  invoices           Invoice[]
  napboxPort         NapboxPort?
  installations      Installation[]

  @@map("client")
}

model Invoice {
  id            Int            @id @default(autoincrement())
  clientId      Int

  amount        Float
  billingDate   DateTime
  dueDate       DateTime

  status        InvoiceStatus  @default(pending)
  paidDate      DateTime?
  paymentMethod PaymentMethod?

  referenceNumber  String?
  createdAt     DateTime @default(now())

  client        Client   @relation(fields: [clientId], references: [id])

  @@index([clientId], map: "Invoice_clientId_idx")
  @@unique([clientId, billingDate])

  @@map("invoice")
}

model Payment {
  id            Int      @id @default(autoincrement())
  clientId      Int
  amount        Float
  paymentDate   DateTime @default(now())
  method        PaymentMethod?
  createdAt     DateTime @default(now())
  client        Client   @relation(fields: [clientId], references: [id])
  referenceNumber  String?
  
  @@index([clientId], map: "Payment_clientId_idx")
  @@map("payment")
}

model Napbox {
  id         Int           @id @default(autoincrement())
  name       String
  location   String
  totalPorts Int
  availablePorts Int
  occupiedPorts  Int
  faultyPorts    Int
  installDate DateTime
  status     String
  ports      NapboxPort[]
  installations Installation[]

  @@map("napbox")
}

model NapboxPort {
  id        Int      @id @default(autoincrement())
  portNumber Int
  status     String   
  napbox     Napbox   @relation(fields: [napboxId], references: [id])
  napboxId   Int
  client     Client?  @relation(fields: [clientId], references: [id])
  clientId   Int?     @unique
  connectedSince DateTime?

  @@map("napboxport")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@map("user")
}

model EmailOTP {
  id        Int      @id @default(autoincrement())
  email     String
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("emailotp")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("passwordresettoken")
}

model Technician {
  id            Int            @id @default(autoincrement())
  name          String
  contactNumber String?
  area          String?
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  installations Installation[]

  @@map("technician")
}

model Installation {
  id              Int         @id @default(autoincrement())
  clientId        Int?
  client          Client?     @relation(fields: [clientId], references: [id])
  technicianId    Int?
  technician      Technician? @relation(fields: [technicianId], references: [id])
  scheduledDate   DateTime?
  completedDate   DateTime?
  status          String      @default("pending")
  notes           String?
  prospectName    String?
  prospectPhone   String?
  prospectAddress String?
  convertedAt     DateTime?

  // Fiber information
  napboxId        Int?
  napbox          Napbox?     @relation(fields: [napboxId], references: [id])
  portNumber      Int?
  fiberCore       String?
  dropCableLength Float?

  // Device information
  onuSerial       String?
  routerSerial    String?
  macAddress      String?

  // Signal readings (dBm)
  rxReading       Float?
  txReading       Float?

  // GPS location of client premises
  latitude        Float?
  longitude       Float?

  materials       InstallationMaterial?
  photos          InstallationPhoto[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("installation")
}

model InstallationPhoto {
  id             Int          @id @default(autoincrement())
  installationId Int
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  url            String
  publicId       String
  category       String
  caption        String?
  createdAt      DateTime     @default(now())

  @@index([installationId])
  @@map("installationphoto")
}

model InstallationMaterial {
  id             Int          @id @default(autoincrement())
  installationId Int          @unique
  installation   Installation @relation(fields: [installationId], references: [id])
  dropCable      Float?
  scConnector    Int?
  cableTies      Int?
  clamps         Int?
  patchCord      Int?
  submittedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("installationmaterial")
}
